# Propicks — variabili d'ambiente
#
# Copia questo file in `.env` (gitignored) e compila i valori.
# Il framework le carica via python-dotenv (override=False: la shell vince).

# ---------------------------------------------------------------------------
# AI validation (Claude) — obbligatorio per --validate dei CLI scan/contra/rotate
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Opzionali:
# PROPICKS_AI_MODEL=claude-opus-4-6
# PROPICKS_AI_WEB_SEARCH=1
# PROPICKS_AI_WEB_SEARCH_MAX_USES=5
# PROPICKS_AI_MAX_CALLS_PER_DAY=50
# PROPICKS_AI_MAX_COST_USD_PER_DAY=5.0

# ---------------------------------------------------------------------------
# Telegram bot (Phase 4) — obbligatorio per propicks-bot run
# ---------------------------------------------------------------------------
# Setup:
#   1. Telegram → @BotFather → /newbot → ottieni TOKEN
#   2. Invia /start al tuo nuovo bot da Telegram
#   3. @userinfobot → /start → ottieni il tuo CHAT_ID numerico
#
PROPICKS_TELEGRAM_BOT_TOKEN=
PROPICKS_TELEGRAM_CHAT_ID=

# Opzionale: CSV per multi-chat (es. partner di trading, famiglia, altro device)
# PROPICKS_TELEGRAM_CHAT_ID=123456,789012

# Opzionale: intervallo poll dispatcher (default 60s)
# PROPICKS_TELEGRAM_POLL_INTERVAL=60
