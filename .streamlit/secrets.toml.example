# Template per Streamlit Community Cloud secrets.
#
# In locale: copia in `.streamlit/secrets.toml` (gitignored) per testare il
# bridge env. In dev locale puoi anche continuare a usare `.env` puro —
# `_bootstrap.py` è no-op se secrets.toml non esiste.
#
# In Streamlit Cloud: incolla queste chiavi nel pannello "Settings → Secrets"
# del deploy. Streamlit le espone via `st.secrets`, `_bootstrap.py` le mappa
# a env vars così il resto del codice resta uniforme.

# --- Database remoto (Turso libSQL) ---
# Senza queste due chiavi la dashboard userà SQLite locale (file su disco
# effimero su Streamlit Cloud → ogni cold start ricomincia vuoto).
# Crea con:
#   turso db create propicks
#   turso db show propicks --url
#   turso db tokens create propicks
TURSO_DATABASE_URL = "libsql://propicks-<user>.turso.io"
TURSO_AUTH_TOKEN = "eyJhbGciOi..."

# --- AI validation (opzionale) ---
# Senza ANTHROPIC_API_KEY i pulsanti `--validate` falliranno con messaggio
# esplicito ma il resto della dashboard (scoring tecnico, portfolio, journal,
# backtest) funziona normale.
# ANTHROPIC_API_KEY = "sk-ant-..."
# PROPICKS_AI_MODEL = "claude-opus-4-6"
# PROPICKS_AI_WEB_SEARCH = "1"
# PROPICKS_AI_WEB_SEARCH_MAX_USES = "5"

# --- Telegram bot (opzionale) ---
# TELEGRAM_BOT_TOKEN = "123:ABC..."
# TELEGRAM_CHAT_ID = "12345"
